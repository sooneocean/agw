{
  "name": "@sooneocean/agw",
  "version": "3.4.0",
  "description": "Agent Gateway — multi-agent task router for Claude, Codex, Gemini with combos, DAG, DSL",
  "type": "module",
  "bin": {
    "agw": "./bin/agw.ts"
  },
  "scripts": {
    "dev": "tsx src/daemon/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "vitest run --testTimeout=60000 --exclude tests/integration/routes-stats.test.ts"
  },
  "keywords": [
    "agent",
    "gateway",
    "multi-agent",
    "claude",
    "codex",
    "gemini",
    "ai",
    "orchestration",
    "combo",
    "pipeline",
    "dsl"
  ],
  "author": "sooneocean",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sooneocean/agw.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "ui/",
    "tsconfig.json"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "better-sqlite3": "^11.8.0",
    "commander": "^13.1.0",
    "fastify": "^5.2.0",
    "nanoid": "^5.1.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
